MAIL_FROM=Notion Calendar <noreply@calendar.silasbeckmann.de>

# App
BASE_URL=https://calendar.silasbeckmann.de
DATABASE_URL=sqlite:////app/config/app.db
CACHE_TTL=600

# Impressum (shown on /imprint)
IMPRINT_NAME=
IMPRINT_ADDRESS=
