# Notion OAuth (https://www.notion.so/my-integrations → Public Integration)
NOTION_OAUTH_CLIENT_ID=
NOTION_OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_URI=https://calendar.silasbeckmann.de/oauth/callback

# Secrets
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=
# openssl rand -hex 32
SESSION_SECRET=

# Email (https://resend.com)
RESEND_API_KEY=
MAIL_FROM=Notion Calendar <noreply@calendar.silasbeckmann.de>

# App
BASE_URL=https://calendar.silasbeckmann.de
DATABASE_URL=sqlite:////app/config/app.db
CACHE_TTL=600

# Impressum (shown on /imprint) — zeige hier z.B. kontakt@calendar.silasbeckmann.de
IMPRINT_NAME=
IMPRINT_ADDRESS=
IMPRINT_EMAIL=

# Inbound-Mail-Forwarding: Resend empfängt Mails an IMPRINT_EMAIL,
# unser Webhook leitet sie an ADMIN_EMAIL (deine private Adresse) weiter.
# RESEND_WEBHOOK_SECRET kommt aus dem Webhook-Setup im Resend-Dashboard.
ADMIN_EMAIL=
RESEND_WEBHOOK_SECRET=
